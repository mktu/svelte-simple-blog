{
	"name": "svelte-blog",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "rm -rf build && vite build",
		"build:test": "rm -rf build && NODE_ENV=test vite build --mode test",
		"deploy": "rm -rf node_modules/.cache/gh-pages && npm run build && gh-pages -d build -t true",
		"package": "svelte-kit package",
		"preview": "NODE_ENV=test vite preview",
		"test": "playwright test",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --ignore-path .gitignore --check . && eslint --ignore-path .gitignore .",
		"format": "prettier --ignore-path .gitignore --write ."
	},
	"devDependencies": {
		"@playwright/test": "1.33.0",
		"@sveltejs/adapter-static": "3.0.10",
		"@sveltejs/kit": "2.66.0",
		"@sveltejs/vite-plugin-svelte": "4.0.4",
		"@typescript-eslint/eslint-plugin": "5.62.0",
		"@typescript-eslint/parser": "5.62.0",
		"eslint": "8.42.0",
		"eslint-config-prettier": "8.8.0",
		"eslint-plugin-svelte": "2.46.1",
		"gh-pages": "5.0.0",
		"prettier": "3.8.4",
		"prettier-plugin-svelte": "4.1.1",
		"sass": "1.101.0",
		"svelte": "5.56.3",
		"svelte-check": "4.6.0",
		"svelte-preprocess": "6.0.5",
		"tslib": "2.6.3",
		"typescript": "5.9.3",
		"vite": "5.4.21"
	},
	"type": "module",
	"dependencies": {
		"date-fns": "2.30.0",
		"newt-client-js": "3.2.8",
		"svelte-intersection-observer": "1.1.1",
		"svelte-meta-tags": "5.0.0"
	}
}
